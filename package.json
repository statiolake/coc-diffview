{
  "name": "@statiolake/coc-diffview",
  "version": "0.1.0",
  "description": "Editable unified and side-by-side diff UI for coc.nvim",
  "author": "statiolake",
  "license": "MIT",
  "main": "lib/index.js",
  "types": "index.d.ts",
  "engines": {
    "coc": "^0.0.82"
  },
  "activationEvents": [
    "*"
  ],
  "scripts": {
    "build": "node esbuild.mjs",
    "prepare": "node esbuild.mjs",
    "test": "node --no-warnings --experimental-strip-types --test src/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "contributes": {
    "commands": [
      {
        "command": "coc-diffview.open",
        "title": "Open Diff"
      },
      {
        "command": "coc-diffview.close",
        "title": "Close File Diff"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Coc Diffview",
      "properties": {
        "coc-diffview.layout": {
          "type": "string",
          "enum": ["unified", "split"],
          "default": "unified",
          "description": "Default file diff layout."
        }
      }
    }
  },
  "devDependencies": {
    "@types/node": "^16.18.0",
    "coc.nvim": "^0.0.83-next.24",
    "esbuild": "^0.25.0",
    "typescript": "^5.3.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/statiolake/coc-diffview.git"
  },
  "bugs": {
    "url": "https://github.com/statiolake/coc-diffview/issues"
  },
  "homepage": "https://github.com/statiolake/coc-diffview#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "index.d.ts",
    "lib/index.js"
  ]
}
